{
  "name": "ft-engine",
  "productName": "FT Engine",
  "version": "1.9.0",
  "description": "Professional Electronic Referee System by freakthrow",
  "main": "./out/main/index.js",
  "author": {
    "name": "Evan Zhong",
    "email": "freakthrow@gmail.com"
  },
  "homepage": "https://evannzhongg.github.io/",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck": "tsc -p tsconfig.ipc.json",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "node --test tests/app-lifecycle.test.mjs tests/competition-service.test.mjs tests/device-lifecycle.test.mjs tests/export-boundary.test.mjs tests/export-service.test.mjs tests/local-database.test.mjs tests/main-boundary.test.mjs tests/match-boundary.test.mjs tests/match-progress.test.mjs tests/match-session.test.mjs tests/platform-worker-manager.test.mjs tests/project-boundary.test.mjs tests/realtime-boundary.test.mjs tests/replay-scores.test.mjs tests/scoring-domain.test.mjs tests/security-boundary.test.mjs tests/settings-boundary.test.mjs tests/stage-boundary.test.mjs tests/stage-renderer.test.mjs tests/stage-service.test.mjs tests/window-layout.test.mjs tests/worker-client.test.mjs tests/youtube-media.test.mjs",
    "build:worker": "node scripts/build-worker.js",
    "build:worker:win": "powershell -ExecutionPolicy Bypass -File ./scripts/build-worker-win.ps1",
    "build:worker:mac": "bash ./scripts/build-worker-mac.sh",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build:worker:win && npm run build && electron-builder --win",
    "build:mac": "npm run build:worker:mac && npm run build && electron-builder --mac && node scripts/rename-mac-artifacts.js",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.freakthrow.ftengine",
    "productName": "FT Engine",
    "copyright": "Copyright © 2025 freakthrow. All rights reserved.",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "evannzhongg",
        "repo": "ft-engine"
      }
    ],
    "win": {
      "verifyUpdateCodeSignature": false,
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "legalTrademarks": "freakthrow™",
      "extraResources": [
        {
          "from": "./local-platform-worker.exe",
          "to": "local-platform-worker.exe",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "mac": {
      "identity": null,
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSBluetoothAlwaysUsageDescription": "FT Engine 需要访问蓝牙以连接计分控制器",
        "NSBluetoothPeripheralUsageDescription": "FT Engine 需要访问蓝牙以连接计分控制器"
      },
      "extraResources": [
        {
          "from": "./local-platform-worker",
          "to": "local-platform-worker",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "dmg": {
      "backgroundColor": "#1e1e1e",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "nsis": {
      "include": "resources/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "FT Engine",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.1.7",
    "fflate": "^0.8.2",
    "lucide-vue-next": "^0.559.0",
    "pinia": "^3.0.4",
    "sass": "^1.95.1",
    "sass-loader": "^16.0.6",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.2.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0"
  }
}
